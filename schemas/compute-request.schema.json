{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.deterministic-compute.dev/compute-request.schema.json",
  "title": "ComputeRequest",
  "type": "object",
  "additionalProperties": false,
  "required": ["operation", "input"],
  "properties": {
    "operation": {
      "type": "string",
      "description": "Stable operation identifier, such as arithmetic.add, expression.evaluate, units.convert, finance.vat, finance.loan-payment, finance.cagr, verification.compare, or test-generation.generate-expected-values. CAGR supports only exact roots representable at the requested decimalPlaces."
    },
    "input": {
      "type": "object",
      "description": "Operation-specific input payload."
    },
    "precision": {
      "$ref": "#/$defs/PrecisionPolicy",
      "description": "Optional precision and rounding policy."
    },
    "trace": {
      "type": "boolean",
      "description": "Whether the caller requests proof or step metadata.",
      "default": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "operation": {
            "const": "units.convert"
          }
        },
        "required": ["operation"]
      },
      "then": {
        "properties": {
          "input": {
            "$ref": "#/$defs/UnitConversionInput"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation": {
            "const": "finance.vat"
          }
        },
        "required": ["operation"]
      },
      "then": {
        "properties": {
          "input": {
            "$ref": "#/$defs/VatInput"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation": {
            "const": "verification.compare"
          }
        },
        "required": ["operation"]
      },
      "then": {
        "properties": {
          "precision": {
            "description": "Ignored for verification.compare; comparisons use exact numeric values and explicit tolerance."
          },
          "input": {
            "$ref": "#/$defs/VerificationCompareInput"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "operation": {
            "const": "test-generation.generate-expected-values"
          }
        },
        "required": ["operation"]
      },
      "then": {
        "properties": {
          "precision": {
            "description": "Ignored for test-generation.generate-expected-values; each case may carry its own precision policy."
          },
          "input": {
            "$ref": "#/$defs/GenerateExpectedValuesInput"
          }
        }
      }
    }
  ],
  "$defs": {
    "NumericValue": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "value"],
          "properties": {
            "kind": {
              "const": "integer"
            },
            "value": {
              "type": "string",
              "pattern": "^[+-]?\\d+$"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "value", "scale"],
          "properties": {
            "kind": {
              "const": "decimal"
            },
            "value": {
              "type": "string",
              "pattern": "^[+-]?(?:\\d+(?:\\.\\d*)?|\\.\\d+)$"
            },
            "scale": {
              "type": "integer",
              "minimum": 0,
              "maximum": 38,
              "description": "Number of fractional decimal digits serialized in value."
            }
          }
        }
      ]
    },
    "NonNegativeNumericValue": {
      "allOf": [
        {
          "$ref": "#/$defs/NumericValue"
        },
        {
          "not": {
            "properties": {
              "value": {
                "pattern": "^-"
              }
            },
            "required": ["value"]
          }
        }
      ]
    },
    "VerificationTolerance": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "value"],
          "properties": {
            "kind": {
              "const": "absolute"
            },
            "value": {
              "$ref": "#/$defs/NonNegativeNumericValue"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["kind", "value"],
          "properties": {
            "kind": {
              "const": "relative"
            },
            "value": {
              "$ref": "#/$defs/NonNegativeNumericValue",
              "description": "Decimal ratio applied to abs(expected)."
            }
          }
        }
      ]
    },
    "UnitConversionInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "sourceUnit", "targetUnit"],
      "properties": {
        "value": {
          "$ref": "#/$defs/NumericValue"
        },
        "sourceUnit": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32,
          "description": "Supported source unit symbol or name, such as m, cm, ft, kg, lb, s, min, h, C, F, or K."
        },
        "targetUnit": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32,
          "description": "Supported target unit symbol or name compatible with sourceUnit."
        }
      }
    },
    "VatInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["netAmount", "vatRate"],
      "properties": {
        "netAmount": {
          "$ref": "#/$defs/NonNegativeNumericValue"
        },
        "vatRate": {
          "$ref": "#/$defs/NonNegativeNumericValue",
          "description": "Decimal VAT rate, not a percentage whole number."
        }
      }
    },
    "VerificationCompareInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["expected", "actual"],
      "properties": {
        "expected": {
          "$ref": "#/$defs/NumericValue"
        },
        "actual": {
          "$ref": "#/$defs/NumericValue"
        },
        "tolerance": {
          "$ref": "#/$defs/VerificationTolerance"
        }
      }
    },
    "ExpectedValueCaseSpec": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "operation", "input"],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 128,
          "description": "Stable case identifier, limited to 128 UTF-8 bytes by the Rust implementation."
        },
        "operation": {
          "enum": [
            "arithmetic.add",
            "arithmetic.subtract",
            "arithmetic.multiply",
            "arithmetic.divide",
            "expression.evaluate",
            "finance.simple-interest",
            "finance.compound-interest",
            "finance.loan-payment",
            "finance.vat",
            "finance.percentage-change",
            "finance.margin-markup",
            "finance.cagr",
            "units.convert",
            "verification.compare"
          ],
          "description": "Supported compute operation to evaluate for this expected value. Recursive test-generation.generate-expected-values cases are rejected."
        },
        "input": {
          "type": "object",
          "description": "Operation-specific input payload for this case. Serialized JSON must not exceed 16384 bytes."
        },
        "precision": {
          "$ref": "#/$defs/PrecisionPolicy"
        },
        "trace": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "GenerateExpectedValuesInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cases"],
      "properties": {
        "cases": {
          "type": "array",
          "minItems": 1,
          "maxItems": 100,
          "items": {
            "$ref": "#/$defs/ExpectedValueCaseSpec"
          },
          "description": "Cases evaluated in input order."
        },
        "failOnCaseError": {
          "type": "boolean",
          "default": false,
          "description": "When true, any failing generated case fails the whole request."
        },
        "maxCases": {
          "type": "integer",
          "minimum": 1,
          "maximum": 100,
          "description": "Optional caller-specified case limit no greater than 100."
        }
      }
    },
    "PrecisionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "decimalPlaces": {
          "type": "integer",
          "minimum": 0,
          "maximum": 38
        },
        "rounding": {
          "enum": ["exact", "truncate", "half-away-from-zero"],
          "default": "exact"
        }
      }
    }
  }
}
